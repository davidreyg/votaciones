// https://aka.ms/devcontainer.json
{
	"name": "Existing Docker Compose (Extend)",
	"dockerComposeFile": [
		"../compose.yaml"
	],
	"service": "laravel.test",
	"workspaceFolder": "/var/www/html",
	"customizations": {
		"vscode": {
			"extensions": [
				"laravel.vscode-laravel",
				"mikestead.dotenv",
				"amiralizadeh9480.laravel-extra-intellisense",
				"DEVSENSE.phptools-vscode",
				"kisstkondoros.vscode-gutter-preview",
				"vivaxy.vscode-conventional-commits",
				"Gruntfuggly.todo-tree",
				"bradlc.vscode-tailwindcss",
				"shardulm94.trailing-spaces",
				"redhat.vscode-yaml",
				"ctf0.php-array-symbols",
				"usernamehw.errorlens",
				"ms-azuretools.vscode-docker",
				"onecentlin.laravel-blade",
				"codingyu.laravel-goto-view",
				"ahinkle.laravel-model-snippets",
				"shufo.vscode-blade-formatter",
				"onecentlin.laravel5-snippets",
				"pcbowers.alpine-intellisense",
				"damms005.devdb",
				"open-southeners.laravel-pint",
				"SanderRonde.phpstan-vscode"
			],
			"settings": {
				"editor.formatOnSave": true,
				"php.format.codeStyle": "Off",
				"laravel-pint.enable": true,
				"[php]": {
					"editor.defaultFormatter": "open-southeners.laravel-pint"
				}
			}
		}
	},
	"remoteUser": "sail",
	"postCreateCommand": "git config --local include.path ../.gitconfig && chown -R 1000:1000 /var/www/html 2>/dev/null || true",
	"mounts": [
		"source=${localEnv:HOME}/.ssh,target=/home/sail/.ssh,type=bind,consistency=cached"
	],
	"features": {
		"ghcr.io/devcontainers/features/common-utils:2": {
			"installZsh": true,
			"configureZshAsDefaultShell": true,
			"installOhMyZsh": true,
			"installOhMyZshConfig": true,
			"upgradePackages": true,
			"installSsl": true,
			"username": "automatic",
			"userUid": "automatic",
			"userGid": "automatic"
		}
	}
	// "forwardPorts": [],
	// "runServices": [],
	// "shutdownAction": "none",
}